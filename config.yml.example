# AI模型配置
ai:
  # 智谱AI配置
  zhipu:
    api_key: "YOUR_API_KEY_HERE"
    # 文本模型
    text_model: "GLM-4-Flash-250414"
    # 视觉模型 (用于识别板块红色标题) - GLM-4V-Plus 快速，识别单条标题足够
    vision_model: "GLM-4V-Plus"
    base_url: "https://open.bigmodel.cn/api/paas/v4/"
    
  # 默认使用的模型提供商
  default_provider: "zhipu"
  
  # 模型参数
  params:
    temperature: 0.1
    top_p: 0.1
    max_tokens: 4096

# 图片识别配置
ocr:
  # 提取内容配置
  extract:
    # 图片03: 涨跌家数
    image_03:
      - "上涨家数"
      - "下跌家数"
      - "总成交额"
    
    # 图片04: 涨停数据
    image_04:
      - "涨停"
      - "炸板"
      - "跌停"
      - "首版"
      - "连板"
  
  # 板块识别配置
  sectors:
    # 匹配格式
    pattern: "【(.*?)】"
    # 排除的板块
    exclude:
      - "其他"
      - "涨停炸板"
      - "市场连板股"

# 通达信配置
tdx:
  # 通达信量化版安装目录 (留空则自动探测; 探测命中后会自动回写到此, 下次启动直接命中)
  install_dir: ""
  # 本地行情端口 (通达信客户端行情端口, 0=不尝试本地直连直接走远程; 客户端开了7709监听才填7709)
  local_port: 0

# PostgreSQL 数据库配置 (数据入库/热门股追踪)
database:
  host: "localhost"
  port: 15432
  user: "postgres"
  password: "mysecretpassword"
  dbname: "postgres"
